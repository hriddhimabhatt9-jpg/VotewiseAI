<!DOCTYPE html>
<html>
  <head>
    <title>My Live Google Map</title>
    <!-- CSS is required to give the map container a height -->
    <style>
      #map {
        height: 500px;
        width: 100%;
      }
    </style>
  </head>
  <body>
    <h3>My Website Map</h3>
    <!-- The div element where the map will be rendered -->
    <div id="map"></div>

    <!-- Replace YOUR_API_KEY with your actual API Key -->
    <script async src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCmIRb91zrRaKbolwBzohDpZfWrwXU2Sgw&callback=initMap">
    </script>

    <script>
      function initMap() {
        // The location of your map center (Example: New York)
        const location = { lat: 40.7128, lng: -74.0060 };
        // The map, centered at the location
        const map = new google.maps.Map(document.getElementById("map"), {
          zoom: 12,
          center: location,
        });
        // Optional: The marker, positioned at the location
        const marker = new google.maps.Marker({
          position: location,
          map: map,
        });
      }
    </script>
  </body>
</html>
